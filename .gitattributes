# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.rs        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.svg       text eol=lf

# Windows-specific
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.woff      binary
*.woff2     binary
*.mp3       binary
*.wav       binary
*.ogg       binary
*.db        binary
*.spn       binary
*.res       binary
*.exe       binary
*.dll       binary
